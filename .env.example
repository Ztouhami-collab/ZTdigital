# Anthropic API key used by the URL analyzer (app/api/analyze/route.ts).
# Copy this file to .env.local and paste your key. Never commit .env.local.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override the model. Defaults to claude-sonnet-4-6.
# De web_search-tool (web_search_20260209) vereist Sonnet 4.6 of nieuwer.
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Resend API key voor het contactformulier (app/api/contact/route.ts).
# Maak een account op resend.com (gratis tot 3000 emails/maand) en verifieer
# het domein ztdigital.nl in het Resend-dashboard voor het "from"-adres.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Optioneel: overschrijf de afzender / ontvanger.
# CONTACT_FROM=ZT Digital <noreply@ztdigital.nl>
# CONTACT_TO=info@ztdigital.nl
